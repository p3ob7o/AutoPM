# Copy to .env and fill in. .env is gitignored; never commit real values.
# These are the names instances/<slug>/config.yaml vault entries reference
# as env:VAR_NAME; values resolve from the deploy host's environment.
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
LINEAR_API_KEY=
# Optional — only if the Support role is deployed (config.yaml vault.helpdesk):
# HELPDESK_TOKEN=
